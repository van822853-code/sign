# Frontend calls the Cloudflare Worker API.
# Local dev default: `http://127.0.0.1:8787` and auto-fallback to nearby local ports.
# Production fallback without this value is same-origin `/api`.
VITE_EVENT_API_BASE="http://127.0.0.1:8787"

# Legacy override. Current upload flow uses the same Worker proxy as event APIs.
VITE_UPLOAD_API_BASE=""
